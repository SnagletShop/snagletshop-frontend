{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "target": "ES2022",
    "module": "none",
    "lib": ["ES2022", "DOM"],
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "useDefineForClassFields": false
  },
  "include": ["script.js", "src/**/*.js"]
}
